<.focus_box>
  <:title>
    Track how AI recommends your business
  </:title>

  <p>
    Privacy-friendly analytics for the AI era. See exactly how
    ChatGPT, Claude, Perplexity, and Gemini describe you — and get a
    monthly DIY AEO report so you can actually move the needle.
  </p>

  <p class="mt-4 text-sm text-gray-500 dark:text-gray-400">
    <b class="text-gray-900 dark:text-gray-100">$49/month</b>
    · 7-day free trial · No setup call · Cancel anytime
  </p>

  <div class="mt-6">
    <.button_link
      href="https://buy.stripe.com/8x2eV78Ws36B0yA0WZ3Nm00"
      new_tab={true}
      mt?={false}
      class="w-full"
    >
      Start your 7-day free trial →
    </.button_link>
  </div>

  <:footer>
    <.focus_list>
      <:item>
        <.styled_link href={Routes.auth_path(@conn, :login)}>
          Already have an account? Log in
        </.styled_link>
      </:item>
      <:item>
        <.styled_link href="https://foundforai.com/pricing" new_tab={true}>
          Want done-for-you instead? See the AI Operator Subscription
        </.styled_link>
      </:item>
      <:item>
        <.styled_link href="https://x.com/FoundForAI" new_tab={true}>
          Follow on X
        </.styled_link>
      </:item>
    </.focus_list>
  </:footer>
</.focus_box>
